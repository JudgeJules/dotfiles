# .envrc — Node project environment
# Managed by direnv. Run `direnv allow` after copying to your project.
#
# direnv loads this automatically when you cd into the directory,
# and unloads it when you leave.

# Load .env file if present (never commit .env — add it to .gitignore)
dotenv_if_exists .env

# Switch to the Node version specified in .nvmrc (create one if missing)
# Example .nvmrc content: lts/iron
if command -v fnm &>/dev/null; then
    fnm use --silent-if-unchanged 2>/dev/null || true
fi
