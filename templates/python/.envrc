# .envrc — Python project environment
# Managed by direnv. Run `direnv allow` after copying to your project.
#
# direnv loads this automatically when you cd into the directory,
# and unloads it when you leave.

# Load .env file if present (never commit .env — add it to .gitignore)
dotenv_if_exists .env

# Activate uv venv if it exists
# Run `just install` first to create it
if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

# Add src to PYTHONPATH so imports work without installing the package
# Remove if your project uses a proper install (pyproject.toml + uv pip install -e .)
export PYTHONPATH="$PWD/src:$PYTHONPATH"
