#!/usr/bin/env bash
#
# ~/.config/git/hooks/pre-commit
# --------------------------------
# Global pre-commit hook — runs on every repo on this machine.
# Scans staged files for secrets using gitleaks before allowing a commit.
#
# If gitleaks isn't installed yet (e.g. on a fresh machine before Brewfile
# runs), the hook warns but does NOT block the commit.
#
# To bypass in an emergency: git commit --no-verify
# (use sparingly — bypassing defeats the purpose)

if ! command -v gitleaks &> /dev/null; then
  echo "⚠  gitleaks not found — secret scanning skipped"
  echo "   Install with: brew install gitleaks"
  exit 0
fi

# Scan only staged files (not the full repo history)
gitleaks protect --staged --redact --no-banner

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "✘  gitleaks found potential secrets in staged files."
  echo ""
  echo "   Fix the issue, then re-stage and commit."
  echo "   If this is a false positive, add an inline comment:"
  echo "     # gitleaks:allow"
  echo ""
  echo "   To bypass (emergencies only): git commit --no-verify"
  exit 1
fi

exit 0
