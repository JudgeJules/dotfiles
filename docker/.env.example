# docker/.env.example
# ---------------------
# Copy this to docker/.env and fill in the values.
# .env is gitignored — never commit real values.
#
# WEBUI_SECRET_KEY should be stored in 1Password:
#   1. Generate: openssl rand -hex 32
#   2. Save to 1Password as "Open WebUI Secret Key"
#   3. Paste the value below (it only lives on this machine, not in the repo)

# ── Open WebUI ────────────────────────────────────────────────────────────────

# Required. Cryptographic secret for session signing.
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# Enable authentication (always leave true — disabling exposes the UI to anyone on your network)
WEBUI_AUTH=true

# ── Ollama ────────────────────────────────────────────────────────────────────

# Ollama runs natively on the Mac for Metal GPU acceleration (not in Docker).
# host.docker.internal resolves to the Mac's IP from inside a Docker container.
# Only change this if you are running Ollama on a different host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
